# Backend .env.example - copy to .env and fill in values

NODE_ENV=development
PORT=3000

# Database (Supabase PostgreSQL)
# Transaction pooler for app queries
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Direct connection for migrations
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Supabase
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Modal Kokoro TTS (for audio generation)
KOKORO_TTS_URL=https://your-modal-app--kokoro-tts-speech.modal.run
MODAL_AUTH_KEY=your-modal-auth-key
MODAL_AUTH_SECRET=your-modal-auth-secret

# PostHog (OpenTelemetry logging)
POSTHOG_API_KEY=phc_your_project_api_key
POSTHOG_HOST=https://us.i.posthog.com

# ── Domain Provisioning (Vercel API) ─────────────────────────────────
# Required for automated domain provisioning when creating new brands
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxx
VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxxxxxx
VERCEL_API_TOKEN=xxxxxxxxxxxxxxxxxxxx
