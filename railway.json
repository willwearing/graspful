{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "bun install && cd /app/packages/shared && bun run build && cd /app/backend && bun x prisma generate && bun x nest build"
  },
  "deploy": {
    "startCommand": "cd /app/backend && TS_NODE_PROJECT=tsconfig.runtime.json node --experimental-require-module -r tsconfig-paths/register dist/main",
    "healthcheckPath": "/api/v1/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
